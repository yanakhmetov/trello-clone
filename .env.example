# ============================================
# Docker Environment Configuration Template
# ============================================
# Copy this file to .env.docker and fill in your values
# Never commit .env.docker to version control!

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/trello"

# PostgreSQL Container Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trello
POSTGRES_PORT=5432

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-secure-secret"

# Application Port
APP_PORT=3000

# Node Environment
NODE_ENV=development